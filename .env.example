# Server
NODE_ENV=
PORT=
CLIENT_URL=

# Database (local: Docker Postgres 17, production: Neon)
DATABASE_URL=

# Test database (REQUIRED for running tests — must be local, never remote)
TEST_DATABASE_URL=postgresql://skills_dev:skills_dev@localhost:5432/quizzly_test

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# Anthropic LLM
ANTHROPIC_API_KEY=

# Encryption (generate with: openssl rand -hex 32)
API_KEY_ENCRYPTION_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Error Tracking (optional — leave empty to disable)
SENTRY_DSN=

# Client (Vite exposes only VITE_-prefixed vars to the browser)
# Set VITE_API_URL to the backend origin (no /api suffix)
VITE_API_URL=
VITE_SENTRY_DSN=
